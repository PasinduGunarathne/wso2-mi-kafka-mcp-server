{
  "name": "kafka-mi-mcp-server",
  "version": "2.0.0",
  "description": "MCP Server — complete local Kafka + WSO2 MI integration engineering platform (26 tools). Works with Claude Desktop, Claude Code, Cursor, Windsurf, Codex, Zed, Continue.dev, and any MCP-compatible client.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.3.0",
    "execa": "^9.3.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
